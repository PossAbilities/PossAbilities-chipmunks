# ── Security (REQUIRED in production) ─────────────────────────
# Long random string used to sign login cookies
SESSION_SECRET=change-me-to-a-long-random-string
# Password for the Admin area (/admin)
ADMIN_PASSWORD=change-me
# PIN Activity Champions use on the check-in register (/champion)
CHAMPION_PIN=2468
# Secret for the reminder cron endpoint (/api/cron/reminders)
CRON_SECRET=change-me-too

# ── Email (optional — without either of these, emails stay in the Admin outbox) ──
# Recommended: Resend (https://resend.com) — just an API key, no SMTP setup
RESEND_API_KEY=
EMAIL_FROM="The Chipmunks at PossAbilities <chipmunks@possabilities.org.uk>"

# Alternative: any SMTP provider — used only if RESEND_API_KEY isn't set
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="The Chipmunks at PossAbilities <chipmunks@possabilities.org.uk>"

# ── Misc ──────────────────────────────────────────────────────
# Where the SQLite database + child photos are stored (default: ./data)
# CHIPMUNKS_DATA_DIR=/var/lib/chipmunks
# Base URL used by scripts/send-reminders.mjs
# APP_URL=https://chipmunks.possabilities.org.uk
